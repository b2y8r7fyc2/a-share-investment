/* 全局样式 - 暗黑金融风 */
page {
  background: #0f1117;
  color: #e0e0e0;
  font-family: -apple-system, 'PingFang SC', sans-serif;
}
.card {
  background: #1a1f2e;
  border: 1px solid #2a2f3e;
  border-radius: 12px;
  padding: 20px;
  margin: 12px 16px;
}
.btn-primary {
  background: linear-gradient(135deg, #ffd93d, #ff6b6b);
  color: #000;
  border: none;
  border-radius: 8px;
  padding: 12px 24px;
  font-weight: 600;
}
.badge-s { background: #1b5e20; color: #6bcb77; }
.badge-a { background: #0d3b2e; color: #4dd0e1; }
.badge-b { background: #3e2723; color: #ffb74d; }
.badge-d { background: #b71c1c; color: #ff8a80; }
.badge {
  padding: 2px 10px;
  border-radius: 10px;
  font-size: 11px;
  font-weight: 600;
}
.up { color: #6bcb77; }
.down { color: #ff6b6b; }
.warn { color: #ffd93d; }
.pred-up { color: #6bcb77; font-weight: 700; }
.pred-down { color: #ff6b6b; font-weight: 700; }
